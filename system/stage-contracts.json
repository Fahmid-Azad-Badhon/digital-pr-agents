{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stage Contracts - Single Source of Truth",
  "version": "1.1.0",
  "lastUpdated": "2026-06-21",
  "stages": {
    "S1_CAMPAIGN_INTAKE": {
      "description": "Initial campaign creation, brief capture, and topic expansion",
      "requires": ["00-brief.md"],
      "produces": ["01-campaign-intake.json"],
      "allowedModelRoles": ["flagship_orchestrator"],
      "modelRouting": { "primary": "Nemotron 3 Ultra", "fallback1": "Nemotron 3 Super", "fallback2": "GPT-OSS-120B" },
      "canContinueAutomatically": true,
      "humanApprovalRequired": false
    },
    "S2_DATA_EXTRACTION": {
      "description": "Extract maximum useful data from provided source material",
      "requires": ["00-brief.md", "source-files/study-inputs/raw-study-copy.md"],
      "produces": ["01-study-notes.md", "02-insights.md", "02-raw-extracted-data.json"],
      "allowedModelRoles": ["research_extraction"],
      "modelRouting": { "primary": "Nemotron 3 Super", "fallback1": "GPT-OSS-120B", "fallback2": "Gemma 4 31B" },
      "canContinueAutomatically": true,
      "humanApprovalRequired": false
    },
    "S3_RESEARCH_ENRICHMENT": {
      "description": "Enrich extracted data with credible outside context",
      "requires": ["02-raw-extracted-data.json", "source-registry.json"],
      "produces": ["03-research.md", "03-research-enrichment.json", "evidence-pack.md", "claim-ledger.json"],
      "allowedModelRoles": ["research_extraction", "flagship_orchestrator"],
      "modelRouting": { "primary": "Nemotron 3 Super", "fallback1": "Nemotron 3 Ultra", "fallback2": "Qwen3 Coder" },
      "canContinueAutomatically": true,
      "humanApprovalRequired": false
    },
    "S4A_DATA_RESEARCH_ANALYST": {
      "description": "Verify, rank, clean, classify findings from S1-S3",
      "requires": ["03-research-enrichment.json", "evidence-pack.md", "claim-ledger.json"],
      "produces": ["verified-findings.json", "verified-claim-map.json"],
      "allowedModelRoles": ["reasoning_judge", "research_extraction"],
      "modelRouting": { "primary": "GPT-OSS-120B", "fallback1": "Nemotron 3 Super", "fallback2": "Nemotron 3 Ultra" },
      "gateAfter": "G2_VERIFIED_FINDINGS_GATE",
      "canContinueAutomatically": true,
      "humanApprovalRequired": false
    },
    "S4B_INSIGHT_ANALYST": {
      "description": "Turn verified findings into story logic",
      "requires": ["verified-findings.json", "verified-claim-map.json", "evidence-pack.md"],
      "produces": ["InsightAnalysisMap.json", "AngleGenerationHandoff.json"],
      "allowedModelRoles": ["flagship_orchestrator", "reasoning_judge"],
      "modelRouting": { "primary": "Nemotron 3 Ultra", "fallback1": "GPT-OSS-120B", "fallback2": "Nemotron 3 Super" },
      "canContinueAutomatically": true,
      "humanApprovalRequired": false
    },
    "S5A_RAW_ANGLES": {
      "description": "Generate raw angles from verified insights before journalist framing",
      "requires": ["AngleGenerationHandoff.json", "InsightAnalysisMap.json", "claim-ledger.json"],
      "produces": ["05a-raw-angles.json"],
      "allowedModelRoles": ["flagship_orchestrator"],
      "modelRouting": { "primary": "Nemotron 3 Ultra", "fallback1": "Hermes 3 405B", "fallback2": "GPT-OSS-120B" },
      "canContinueAutomatically": true,
      "humanApprovalRequired": false
    },
    "S5B_JOURNALIST_FRAMED_ANGLES": {
      "description": "Reframe raw angles with journalist perspective and beat context",
      "requires": ["05a-raw-angles.json", "AngleGenerationHandoff.json"],
      "produces": ["05b-journalist-framed-angles.json"],
      "allowedModelRoles": ["natural_writing_polish"],
      "modelRouting": { "primary": "Hermes 3 405B", "fallback1": "MiniMax M2.5", "fallback2": "GPT-OSS-120B" },
      "canContinueAutomatically": true,
      "humanApprovalRequired": false
    },
    "S5_ANGLE_GENERATION": {
      "description": "Create strong, data-led, journalist-friendly campaign angles",
      "requires": ["AngleGenerationHandoff.json", "InsightAnalysisMap.json", "claim-ledger.json"],
      "produces": ["05-angles.md", "05-angles.json"],
      "allowedModelRoles": ["flagship_orchestrator", "production_writer"],
      "modelRouting": { "primary": "Nemotron 3 Ultra", "fallback1": "Hermes 3 405B", "fallback2": "GPT-OSS-120B" },
      "gateAfter": "G3_ANGLE_QUALITY_GATE",
      "canContinueAutomatically": true,
      "humanApprovalRequired": false,
      "usesJournalistPsychologyLayer": true,
      "usesEmotionalIntelligenceLayer": true,
      "journalistToneRequired": true,
      "dataLedToneRequired": true,
      "newsworthinessCheckRequired": true,
      "emotionalRiskCheckRequired": true,
      "sensitiveTopicCheckRequired": true,
      "antiSalesCheckRequired": true,
      "anglePsychologyOutput": true
    },
    "S6_BEAT_MATCHING": {
      "description": "Map each angle to journalist beats and publication types",
      "requires": ["05-angles.json", "InsightAnalysisMap.json"],
      "produces": ["06-beat-match.md", "06-beat-match.json"],
      "allowedModelRoles": ["fast_prefilter", "reasoning_judge"],
      "modelRouting": { "primary": "Nemotron 3 Nano 30B", "fallback1": "Nemotron 3 Super", "fallback2": "GPT-OSS-120B" },
      "canContinueAutomatically": true,
      "humanApprovalRequired": false
    },
    "S7_PITCH_SELECTION_HUMAN_GATE": {
      "description": "Human review point - score angles, pause workflow, require human approval",
      "requires": ["05-angles.json", "06-beat-match.json", "claim-ledger.json"],
      "produces": ["07-selected-angle.md", "07-selected-angle.json", "human-approval.json"],
      "allowedModelRoles": ["reasoning_judge", "flagship_orchestrator"],
      "modelRouting": { "primary": "GPT-OSS-120B", "fallback1": "Nemotron 3 Ultra", "fallback2": "Nemotron 3 Super" },
      "gateAfter": "G4_HUMAN_SELECTION_GATE",
      "canContinueAutomatically": false,
      "humanApprovalRequired": true
    },
    "S8A_JOURNALIST_COLLECTION": {
      "description": "Perform bulk journalist collection for selected angle",
      "requires": ["human-approval.json", "07-selected-angle.json", "06-beat-match.json"],
      "produces": ["08a-journalist-collection.json"],
      "allowedModelRoles": ["fast_prefilter"],
      "modelRouting": { "primary": "Nemotron 3 Nano 30B", "fallback1": "Nemotron 3 Super", "fallback2": "Qwen3 Coder" },
      "canContinueAutomatically": true,
      "humanApprovalRequired": false
    },
    "S8B_JOURNALIST_RELEVANCE_FILTER": {
      "description": "Filter collected journalists by relevance to selected angle",
      "requires": ["08a-journalist-collection.json", "07-selected-angle.json"],
      "produces": ["08b-relevant-journalists.json"],
      "allowedModelRoles": ["fast_prefilter"],
      "modelRouting": { "primary": "Nemotron 3 Nano 30B", "fallback1": "Nemotron 3 Super", "fallback2": "GPT-OSS-120B" },
      "canContinueAutomatically": true,
      "humanApprovalRequired": false
    },
    "S8_JOURNALIST_COLLECTION": {
      "description": "Collect relevant journalists for approved angle",
      "requires": ["human-approval.json", "07-selected-angle.json", "06-beat-match.json"],
      "produces": ["08-journalist-list.csv", "08-journalist-list.json"],
      "allowedModelRoles": ["fast_prefilter"],
      "modelRouting": { "primary": "Nemotron 3 Nano 30B", "fallback1": "Nemotron 3 Super", "fallback2": "Qwen3 Coder" },
      "canContinueAutomatically": true,
      "humanApprovalRequired": false
    },
    "S9_JOURNALIST_INTELLIGENCE": {
      "description": "Analyze journalist fit and prepare personalization",
      "requires": ["08-journalist-list.json", "07-selected-angle.json", "claim-ledger.json"],
      "produces": ["09-journalist-intelligence.json"],
      "allowedModelRoles": ["research_extraction", "reasoning_judge"],
      "modelRouting": { "primary": "Nemotron 3 Super", "fallback1": "GPT-OSS-120B", "fallback2": "MiniMax M2.5" },
      "gateAfter": "G5_JOURNALIST_FIT_GATE",
      "canContinueAutomatically": true,
      "humanApprovalRequired": false
    },
    "S10_PITCH_DRAFTING": {
      "description": "Draft pitch using approved claims only",
      "requires": ["07-selected-angle.json", "verified-findings.json", "claim-ledger.json", "09-journalist-intelligence.json"],
      "produces": ["10-pitch-draft.md", "10-pitch-draft.json"],
      "allowedModelRoles": ["production_writer"],
      "modelRouting": { "primary": "MiniMax M2.5", "fallback1": "Hermes 3 405B", "fallback2": "GPT-OSS-120B" },
      "gateAfter": "G6_PITCH_SAFETY_GATE",
      "canContinueAutomatically": true,
      "humanApprovalRequired": false,
      "usesJournalistPsychologyLayer": true,
      "usesEmotionalIntelligenceLayer": true,
      "journalistToneRequired": true,
      "dataLedToneRequired": true,
      "newsworthinessCheckRequired": true,
      "deadlineUtilityCheckRequired": true,
      "sourceClarityCheckRequired": true,
      "emotionalRiskCheckRequired": true,
      "sensitiveTopicCheckRequired": true,
      "antiSalesCheckRequired": true,
      "ctaSoftnessCheckRequired": true,
      "emotionalToneOutput": "emotional-tone-checks.json",
      "journalistPsychologyOutput": "journalist-psychology-checks.json",
      "requiresBeatFitCheck": true,
      "beatFitCheckFile": "beat-fit-check.json"
    },
    "S11_PITCH_OPTIMIZATION": {
      "description": "Improve pitch without changing facts",
      "requires": ["10-pitch-draft.md", "claim-ledger.json"],
      "produces": ["11-optimized-pitch.md"],
      "allowedModelRoles": ["natural_writing_polish", "production_writer"],
      "modelRouting": { "primary": "Hermes 3 405B", "fallback1": "MiniMax M2.5", "fallback2": "GPT-OSS-120B" },
      "canContinueAutomatically": true,
      "humanApprovalRequired": false,
      "usesJournalistPsychologyLayer": true,
      "usesEmotionalIntelligenceLayer": true,
      "journalistToneRequired": true,
      "dataLedToneRequired": true,
      "newsworthinessCheckRequired": true,
      "deadlineUtilityCheckRequired": true,
      "sourceClarityCheckRequired": true,
      "emotionalRiskCheckRequired": true,
      "sensitiveTopicCheckRequired": true,
      "antiSalesCheckRequired": true,
      "ctaSoftnessCheckRequired": true
    },
    "S12_PACKAGE_ASSEMBLY": {
      "description": "Assemble complete outreach package",
      "requires": ["11-optimized-pitch.md", "09-journalist-intelligence.json", "claim-ledger.json"],
      "produces": ["12-outreach-package.md", "12-outreach-package.json"],
      "allowedModelRoles": ["production_writer"],
      "modelRouting": { "primary": "MiniMax M2.5", "fallback1": "Qwen3 Coder", "fallback2": "Hermes 3 405B" },
      "canContinueAutomatically": true,
      "humanApprovalRequired": false,
      "usesJournalistPsychologyLayer": true,
      "usesEmotionalIntelligenceLayer": true,
      "journalistToneRequired": true,
      "dataLedToneRequired": true,
      "newsworthinessCheckRequired": true,
      "deadlineUtilityCheckRequired": true,
      "sourceClarityCheckRequired": true,
      "emotionalRiskCheckRequired": true,
      "sensitiveTopicCheckRequired": true,
      "antiSalesCheckRequired": true,
      "ctaSoftnessCheckRequired": true,
      "requiresAssetReadinessCheck": true,
      "assetReadinessFile": "journalist-asset-readiness.json"
    },
    "S13_VALIDATION": {
      "description": "Strict final validation gate",
      "requires": ["12-outreach-package.json", "claim-ledger.json", "verified-findings.json", "human-approval.json"],
      "produces": ["13-validation-report.json", "final-readiness.json"],
      "allowedModelRoles": ["reasoning_judge"],
      "modelRouting": { "primary": "GPT-OSS-120B", "fallback1": "Nemotron 3 Ultra", "fallback2": "Qwen3 Coder" },
      "gateAfter": "G7_FINAL_VALIDATION_GATE",
      "canContinueAutomatically": false,
      "humanApprovalRequired": false,
      "finalGate": true,
      "requiresSourceConfidenceCheck": true,
      "requiresBeatFitCheck": true,
      "requiresUrgencyCheck": true,
      "requiresExclusivityCheck": true,
      "requiresAssetReadinessCheck": true,
      "requiresFinalHumanGutCheck": true,
      "qualityControlFiles": [
        "source-confidence.json",
        "beat-fit-check.json",
        "urgency-check.json",
        "journalist-asset-readiness.json",
        "exclusivity-check.json",
        "final-human-gut-check.json",
        "final-readiness.json"
      ]
    },
    "S14_FINAL_FORMATTING": {
      "description": "Final formatting and quality check",
      "requires": ["13-validation-report.json"],
      "produces": ["10-google-doc.md"],
      "allowedModelRoles": ["strict_formatting", "production_writer"],
      "modelRouting": { "primary": "Qwen3 Coder", "fallback1": "MiniMax M2.5", "fallback2": "Hermes 3 405B" },
      "canContinueAutomatically": true,
      "humanApprovalRequired": false
    },
    "S15_OUTREACH_ASSET_CREATION": {
      "description": "Create visual assets for outreach",
      "requires": ["10-google-doc.md"],
      "produces": ["11-follow-ups.md"],
      "allowedModelRoles": ["production_writer"],
      "modelRouting": { "primary": "MiniMax M2.5", "fallback1": "Hermes 3 405B", "fallback2": "GPT-OSS-120B" },
      "canContinueAutomatically": true,
      "humanApprovalRequired": false
    },
    "S16_CAMPAIGN_LOG_LEARNING_LOOP": {
      "description": "Log campaign data and identify learning opportunities",
      "requires": ["11-follow-ups.md"],
      "produces": ["campaign-log.json"],
      "allowedModelRoles": ["flagship_orchestrator", "reasoning_judge"],
      "modelRouting": { "primary": "Nemotron 3 Ultra", "fallback1": "GPT-OSS-120B", "fallback2": "Nemotron 3 Super" },
      "canContinueAutomatically": true,
      "humanApprovalRequired": false
    }
  },
  "gates": {
    "G0A_TOPIC_EXPANSION_GATE": { "description": "Validates S1", "passIf": ["topic-expansion-map.json exists"], "blockIf": ["missing"] },
    "G1_DATA_RELIABILITY_GATE": { "description": "Validates S2", "passIf": ["02-raw-extracted-data.json exists"], "blockIf": ["no data"] },
    "G1B_RESEARCH_ENRICHMENT_GATE": { "description": "Validates S3", "passIf": ["03-research-enrichment.json exists"], "blockIf": ["missing"] },
    "G2_VERIFIED_FINDINGS_GATE": { "description": "Validates S4A", "passIf": ["verified-findings.json exists"], "blockIf": ["no findings"] },
    "G3_ANGLE_QUALITY_GATE": { "description": "Validates S5", "passIf": ["angles exist", "one scores 80+"], "blockIf": ["no good angles"] },
    "G4_HUMAN_SELECTION_GATE": { "description": "Validates S7", "passIf": ["human-approval status=approved"], "blockIf": ["no approval"] },
    "G5_JOURNALIST_FIT_GATE": { "description": "Validates S9", "passIf": ["journalists exist"], "blockIf": ["no journalists"] },
    "G6_PITCH_SAFETY_GATE": { "description": "Validates S10", "passIf": ["claims in ledger", "no unsupported"], "blockIf": ["unsupported claim"] },
    "G7_FINAL_VALIDATION_GATE": { "description": "Validates S13", "passIf": ["S13 passed"], "blockIf": ["S13 failed"] },
    "G8_HUMAN_SEND_GATE": { "description": "Final send", "passIf": ["S13 passed", "send approved"], "blockIf": ["not approved"] }
  }
}
