  "states": {
    "not_started": {
      "description": "Campaign created but not started",
      "allowedTransitions": ["preflight_checking"]
    },
    "preflight_checking": {
      "description": "Running preflight checks",
      "allowedTransitions": ["running", "blocked"]
    },
    "running": {
      "description": "Workflow actively executing stages",
      "allowedTransitions": ["stage_completed", "gate_checking", "waiting_for_human_approval", "blocked", "validation_failed"]
    },
    "stage_completed": {
      "description": "Stage finished, checking gates",
      "allowedTransitions": ["running", "gate_checking", "waiting_for_human_approval", "needs_revision", "blocked"]
    },
    "gate_checking": {
      "description": "Evaluating gate conditions",
      "allowedTransitions": ["running", "waiting_for_human_approval", "needs_revision", "blocked"]
    },
    "waiting_for_human_approval": {
      "description": "Waiting for human input (S7, S13, or final send)",
      "allowedTransitions": ["running", "needs_revision", "blocked"]
    },
    "needs_revision": {
      "description": "Stage failed, needs rerun",
      "allowedTransitions": ["running", "blocked"]
    },
    "blocked": {
      "description": "Workflow blocked due to gate failure",
      "allowedTransitions": ["running"]
    },
    "validation_failed": {
      "description": "S13 validation failed",
      "allowedTransitions": ["running", "needs_revision"]
    },
    "ready_for_final_review": {
      "description": "All stages passed, ready for final human review",
      "allowedTransitions": ["ready_to_send", "waiting_for_human_approval"]
    },
    "ready_to_send": {
      "description": "Final send approval obtained",
      "allowedTransitions": ["completed"]
    },
    "completed": {
      "description": "Campaign complete",
      "allowedTransitions": []
    }
  },
  "unsafeTransitions": [
    {
      "from": "waiting_for_human_approval",
      "to": "running",
      "condition": "requires human-approval.json status is approved",
      "blockMessage": "Cannot proceed without human approval"
    },
    {
      "from": "validation_failed",
      "to": "ready_for_final_review",
      "condition": "requires S13 validation passed",
      "blockMessage": "Cannot proceed without passing S13"
    },
    {
      "from": "blocked",
      "to": "ready_to_send",
      "condition": "never allowed",
      "blockMessage": "Cannot send from blocked state"
    },
    {
      "from": "not_started",
