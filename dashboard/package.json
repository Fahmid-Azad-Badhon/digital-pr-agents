{
  "name": "digital-pr-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:3002": "next dev -p 3002",
    "dev:stable": "powershell -ExecutionPolicy Bypass -File .\\scripts\\launch-dashboard-stable.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:model-routing": "vitest run src/tests/model-routing.test.ts",
    "test:dashboard-routing": "vitest run src/tests/dashboard-routing.test.ts",
    "typecheck": "tsc --noEmit",
    "test:dry-run": "vitest run src/tests/dry-run.test.ts",
    "verify:mutation-audit": "node scripts/verify-mutation-audit.mjs",
    "verify:api-guardrails": "node scripts/verify-api-guardrails.mjs",
    "verify:high-risk-audit": "node scripts/verify-high-risk-explicit-audit.mjs",
    "verify:platform-hardening": "node scripts/verify-platform-hardening.mjs",
    "verify:stage-brain-bindings": "node scripts/verify-stage-brain-bindings.mjs",
    "verify:integration-readiness": "node scripts/verify-integration-readiness.mjs",
    "verify:strict-audit-contract": "node scripts/verify-strict-audit-contract.mjs",
    "verify:brain-worker-independence": "node scripts/verify-brain-worker-independence.mjs",
    "verify:orchestration-coverage": "node scripts/verify-orchestration-coverage.mjs",
    "verify:enterprise-depth": "node scripts/verify-enterprise-depth.mjs",
    "verify:enterprise-rollout": "node scripts/verify-enterprise-rollout.mjs",
    "verify:auth-session-roles": "node scripts/verify-auth-session-roles.mjs",
    "verify:session-csrf": "node scripts/verify-session-csrf-guard.mjs",
    "verify:external-hardening": "node scripts/verify-external-hardening.mjs",
    "verify:integration-contract-smoke": "node scripts/verify-integration-contract-smoke.mjs",
    "verify": "npm run typecheck && npm test && npm run lint && npm run build",
    "verify:ci": "npm run verify:mutation-audit && npm run verify:api-guardrails && npm run verify:high-risk-audit && npm run verify:platform-hardening && npm run verify:stage-brain-bindings && npm run verify:integration-readiness && npm run verify:strict-audit-contract && npm run verify:brain-worker-independence && npm run verify:orchestration-coverage && npm run verify:enterprise-depth && npm run verify:enterprise-rollout && npm run verify:auth-session-roles && npm run verify:session-csrf && npm run verify:external-hardening && npm run verify:integration-contract-smoke && npm run build"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "clsx": "2.1.1",
    "date-fns": "3.6.0",
    "diff": "^9.0.0",
    "lucide-react": "0.378.0",
    "next": "14.2.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "2.12.7",
    "sqlite3": "5.1.7",
    "tailwind-merge": "2.3.0",
    "uuid": "9.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/eslint-plugin-next": "^16.2.6",
    "@types/node": "20.12.12",
    "@types/react": "18.3.2",
    "@types/react-dom": "18.3.0",
    "@types/uuid": "9.0.8",
    "autoprefixer": "10.4.19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.3",
    "typescript": "5.4.5",
    "vitest": "^1.6.1"
  }
}
