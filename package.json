{
  "name": "digital-pr-agents",
  "version": "1.0.0",
  "description": "Digital PR Workflow - Journalist Email Pitch Automation System",
  "private": true,
  "author": "Digital PR Team",
  "license": "MIT",
  "homepage": "https://github.com/your-org/digital-pr-agents#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/digital-pr-agents.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "validate": "node scripts/validate-all.js",
    
    "pitch:new": "node scripts/new-pitch-job.js",
    "pitch:draft": "node scripts/draft-study-input.js",
    "pitch:validate": "node scripts/validate-stage.js",
    
    "browser:start": "powershell -ExecutionPolicy Bypass -File scripts/launch-debug-chrome.ps1 -Action Launch",
    "browser:stop": "powershell -ExecutionPolicy Bypass -File scripts/launch-debug-chrome.ps1 -Action Stop",
    "browser:health": "powershell -ExecutionPolicy Bypass -File scripts/launch-debug-chrome.ps1 -Action Status",
    "browser:test": "powershell -ExecutionPolicy Bypass -File scripts/launch-debug-chrome.ps1 -Action Verify",
    
    "muckrack:collect": "node muck-rack-automation/scripts/collect-beat-journalists.js",
    "muckrack:search": "node muck-rack-automation/scripts/search-muckrack.js",
    "muckrack:login": "node muck-rack-automation/scripts/login-muckrack.js",
    
    "export:doc": "node scripts/export-google-doc.js",
    "import:muckrack": "node scripts/import-muckrack-output.js",
    
    "skills:validate": "node skills/validate-skills.js",
    "skills:audit": "node skills/audit-skills.js"
  },
  "dependencies": {
    "next": "14.2.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "uuid": "^9.0.1",
    "fs-extra": "^11.2.0",
    "sqlite3": "^5.1.9",
    "tailwindcss": "^3.4.3",
    "postcss": "^8.4.38",
    "autoprefixer": "^10.4.19"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@types/fs-extra": "^11.0.4",
    "typescript": "^5.4.5",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.3"
  },
  "keywords": [
    "digital-pr",
    "journalist-outreach",
    "media-relations",
    "pitch-automation",
    "muck-rack",
    "serp",
    "seo",
    "pr-automation"
  ]
}